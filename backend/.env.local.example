# ===============================================
# CONFIGURACIÓN LOCAL PARA DESARROLLO Y PRUEBAS
# ===============================================
# Este archivo NO se sube a producción
# Copiar como .env y modificar según necesites

# ===== MODO DE EJECUCIÓN =====
ENVIRONMENT=local
DEBUG=true

# ===== BASE DE DATOS LOCAL =====
# Opción 1: SQLite local (más simple, para pruebas rápidas)
# DATABASE_URL=sqlite:///./local_test.db

# Opción 2: PostgreSQL local (recomendado si tienes PostgreSQL instalado)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/nisira_local

# Opción 3: Conectar a PostgreSQL de producción (CUIDADO - solo lectura recomendada)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ===== VECTOR STORE =====
# Para pruebas locales, usar ChromaDB es más simple
VECTOR_STORE_BACKEND=chroma

# ===== GOOGLE DRIVE =====
ENABLE_GOOGLE_DRIVE=true
GOOGLE_DRIVE_FOLDER_ID=tu_folder_id_aqui
GOOGLE_DRIVE_FOLDER_NAME=NombreCarpetaOpcional
# Opcional: pegar el JSON del service account en una sola linea para evitar montar archivo
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ===== APIs (necesarios) =====
# Copiar tus API keys aqui
GOOGLE_API_KEY=tu_api_key_aqui
OPENROUTER_API_KEY=tu_openrouter_key_aqui

# ===== MODELOS LLM (opcional, override de defaults) =====
# LLM_PROVIDER=openrouter            # openrouter | google | groq
# LLM_MODEL_OPENROUTER=google/gemma-2-9b-it
# LLM_MODEL_GEMINI=gemini-2.0-flash-exp
# LLM_MODEL_GROQ=llama-3.3-70b-versatile
# RAGAS_EVALUATOR_MODEL=gemini-2.0-flash-exp
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_DEVICE=cpu               # cpu | cuda

# ===== RUTAS LOCALES =====
# El sistema detectará automáticamente que es local
LOCAL_DATA_DIR=./data
LOCAL_CHROMA_DIR=./chroma_db_local

# ===== DJANGO =====
DJANGO_SECRET_KEY=local-dev-key-not-for-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
